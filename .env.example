# Database
POSTGRES_USER=inventario
POSTGRES_PASSWORD=changeme
POSTGRES_DB=inventario

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# OpenWA - usa el API key que aparece en los logs de OpenWA al iniciar
OPENWA_API_KEY=owa_k1_xxxxxxxx
OPENWA_SESSION_ID=default
OPENWA_WEBHOOK_SECRET=webhook-secret-change-me
# Opcional; por defecto en Docker: http://backend-api:3000/api/webhooks/openwa
# OPENWA_WEBHOOK_URL=http://backend-api:3000/api/webhooks/openwa