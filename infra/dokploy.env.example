# Copiar TODO este bloque en Dokploy → tu app → Environment
# (no sube por git; el .env local solo sirve en tu PC)

POSTGRES_USER=inventario
POSTGRES_PASSWORD=cambiar-password-seguro
POSTGRES_DB=inventario

JWT_SECRET=cambiar-jwt-secret
JWT_REFRESH_SECRET=cambiar-jwt-refresh-secret

# Una sola key fija — la misma en dashboard OpenWA y en el backend
OPENWA_API_KEY=owa_k1_tu_key_fija_aqui
OPENWA_WEBHOOK_SECRET=webhook-secret-2024

# Nota: OpenWA usa SQLite en volumen zent_openwa_prod (no usa POSTGRES_PASSWORD)
